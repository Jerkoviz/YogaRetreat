@page "/gallery"
@inject IContentfulService ContentfulService
@inject IDialogService DialogService
@inject LanguageService Lang

<PageTitle>@Lang.T("Galerija", "Gallery")</PageTitle>

<div style="padding-top:64px;">
    <MudContainer MaxWidth="MaxWidth.Large" Style="padding:3rem 1rem;">
        <MudText Typo="Typo.h3" Style="margin-bottom:0.5rem;">@Lang.T("Galerija", "Gallery")</MudText>
       @*  <MudText Typo="Typo.body1" Style="color:#5A5A5A; margin-bottom:2.5rem;">
            @Lang.T("Trenuci sa naših retreata", "Moments from our retreats")
        </MudText> *@

        @if (_isLoading)
        {
            <div class="masonry-grid">
                @for (int i = 0; i < 9; i++)
                {
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="@(i % 3 == 0 ? "260px" : "180px")" />
                }
            </div>
        }
        else if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudAlert Severity="Severity.Error">@Lang.T("Nije moguće učitati galeriju. Pokušajte ponovo.", "Unable to load gallery. Please try again.")</MudAlert>
        }
        else if (!_albums.Any())
        {
            <MudAlert Severity="Severity.Info">@Lang.T("Još nema fotografija. Uskoro se vraćamo!", "No photos yet. We'll be back soon!")</MudAlert>
        }
        else
        {
            @foreach (var album in _albums)
            {
                <GalleryGrid Album="album" MaxVisible="9" OnImageClick="OpenLightbox" />
                <MudDivider Style="margin:2rem 0;" />
            }
        }
    </MudContainer>
</div>

@if (_lightboxOpen && _lightboxAlbum is not null)
{
    <MudDialog @bind-IsVisible="_lightboxOpen" Options="_lightboxOptions">
        <TitleContent>
            <div style="display:flex; justify-content:space-between; align-items:center; width:100%;">
                <MudText Typo="Typo.h6">@_lightboxAlbum.Title</MudText>
                <MudText Typo="Typo.body2" Style="color:#9E9A94;">@(_lightboxIndex + 1) / @_lightboxAlbum.ImageUrls.Length</MudText>
            </div>
        </TitleContent>
        <DialogContent>
            <div style="position:relative; text-align:center;">
                <img src="@_lightboxAlbum.ImageUrls[_lightboxIndex]"
                     alt="@($"{_lightboxAlbum.Title} photo {_lightboxIndex + 1}")"
                     style="max-width:100%; max-height:70vh; object-fit:contain;" />
            </div>
        </DialogContent>
        <DialogActions>
            <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" OnClick="LightboxPrev" Disabled="_lightboxIndex == 0" />
            <MudSpacer />
            <MudButton OnClick="CloseLightbox" Color="Color.Default">@Lang.T("Zatvori", "Close")</MudButton>
            <MudSpacer />
            <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" OnClick="LightboxNext" Disabled="_lightboxIndex >= _lightboxAlbum.ImageUrls.Length - 1" />
        </DialogActions>
    </MudDialog>
}

@code {
    private IReadOnlyList<IGalleryAlbum> _albums = Array.Empty<IGalleryAlbum>();
    private bool _isLoading = true;
    private string? _errorMessage;

    private bool _lightboxOpen;
    private IGalleryAlbum? _lightboxAlbum;
    private int _lightboxIndex;

    private readonly DialogOptions _lightboxOptions = new()
    {
        MaxWidth = MaxWidth.Large,
        FullWidth = true,
        CloseButton = true,
        BackdropClick = true
    };

    private static readonly GalleryAlbum _placeAlbum = new(
        Slug: " ",
        Title: " ",
        Description: null,
        CoverImageUrl: "images/place/MRK03028.jpg",
        ImageUrls:
        [
            "images/place/MRK03028.jpg",
            "images/place/MRK03030.jpg",
            "images/place/MRK03039.jpg",
            "images/place/MRK03057.jpg",
            "images/place/MRK03060.jpg",
            "images/place/MRK03064.jpg",
            "images/place/MRK03068.jpg",
            "images/place/MRK03076.jpg",
            "images/place/MRK03083.jpg",
            "images/place/MRK03086.jpg",
            "images/place/MRK03087.jpg",
            "images/place/MRK03092.jpg",
            "images/place/MRK03112.jpg",
            "images/place/borovasuma.jpg",
            "images/place/pogled.jpg",
            "images/place/sajt.jpg",
            "images/place/sajt2.jpg",
            "images/place/sajt3.jpg",
            "images/place/borovasuma2.jpg",
            "images/place/chill.JPEG",
        ],
        Date: new DateTime(2024, 1, 1),
        LinkedEventSlug: null
    );

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var contentfulAlbums = await ContentfulService.GetGalleryAlbumsAsync();
            _albums = new[] { _placeAlbum }.Concat(contentfulAlbums).ToList();
        }
        catch (Exception)
        {
            _albums = [_placeAlbum];
            _errorMessage = null;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void OpenLightbox((IGalleryAlbum album, int index) args)
    {
        _lightboxAlbum = args.album;
        _lightboxIndex = args.index;
        _lightboxOpen = true;
    }

    private void CloseLightbox() => _lightboxOpen = false;

    private void LightboxPrev()
    {
        if (_lightboxIndex > 0) _lightboxIndex--;
    }

    private void LightboxNext()
    {
        if (_lightboxAlbum is not null && _lightboxIndex < _lightboxAlbum.ImageUrls.Length - 1)
            _lightboxIndex++;
    }
}
