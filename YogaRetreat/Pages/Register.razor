@page "/register"
@page "/register/{Slug}"
@inject IContentfulService ContentfulService
@inject LanguageService Lang

<PageTitle>@Lang.T("Prijava", "Register") — @(_event?.Title ?? Lang.T("Yoga Retreat", "Yoga Retreat"))</PageTitle>

<div style="padding-top:64px;">
    @if (_isLoading)
    {
        <MudContainer MaxWidth="MaxWidth.Medium" Style="padding:3rem 1rem;">
            <MudSkeleton Height="60px" Style="margin-bottom:1rem;" />
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="600px" />
        </MudContainer>
    }
    else if (!string.IsNullOrEmpty(_errorMessage))
    {
        <MudContainer MaxWidth="MaxWidth.Medium" Style="padding:3rem 1rem;">
            <MudAlert Severity="Severity.Error">@_errorMessage</MudAlert>
        </MudContainer>
    }
    else
    {
        @if (_event is not null)
        {
            <MudPaper Elevation="0" Style="background:linear-gradient(135deg, #6B8C6B22 0%, #C4785A11 100%); padding:2rem 1rem; margin-bottom:0;">
                <MudContainer MaxWidth="MaxWidth.Medium">
                    <MudText Typo="Typo.h4" Style="margin-bottom:0.5rem;">@_event.Title</MudText>
                    <div style="display:flex; gap:1.5rem; flex-wrap:wrap; color:#5A5A5A;">
                        <div style="display:flex; gap:0.4rem; align-items:center;">
                            <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" />
                            <MudText Typo="Typo.body2">
                                @_event.StartDate.ToString("MMM d") – @_event.EndDate.ToString("MMM d, yyyy")
                            </MudText>
                        </div>
                        <div style="display:flex; gap:0.4rem; align-items:center;">
                            <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" />
                            <MudText Typo="Typo.body2">@_event.Location</MudText>
                        </div>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Style="font-weight:600;">
                            &euro;@_event.PriceEur.ToString("N0")
                        </MudText>
                    </div>
                </MudContainer>
            </MudPaper>
        }
        else
        {
            <MudContainer MaxWidth="MaxWidth.Medium" Style="padding:2rem 1rem 0;">
                <MudText Typo="Typo.h4" Style="margin-bottom:0.5rem;">@Lang.T("Prijavite se za retreat", "Register for a Retreat")</MudText>
                <MudText Typo="Typo.body1" Style="color:#5A5A5A; margin-bottom:1rem;">
                    @Lang.T("Popunite formular ispod za prijavu ili upit za jedan od naših retreata.", "Fill in the form below to enquire or register for one of our retreats.")
                </MudText>
            </MudContainer>
        }

        @if (!string.IsNullOrEmpty(_formId))
        {
            <MudContainer MaxWidth="MaxWidth.Medium" Style="padding:2rem 1rem;">
                <iframe src="@($"https://tally.so/embed/{_formId}?alignLeft=1&hideTitle=1&transparentBackground=1")"
                        style="width:100%; height:600px; border:none;"
                        title="Registration form"
                        loading="lazy">
                </iframe>
            </MudContainer>
        }
        else
        {
            <MudContainer MaxWidth="MaxWidth.Medium" Style="padding:2rem 1rem;">
                <MudAlert Severity="Severity.Warning">
                    @Lang.T("Formular za prijavu nije podešen za ovaj retreat. Molimo vas da nas ", "Registration form is not configured for this retreat. Please ")
                    <MudLink Href="@($"mailto:{_contactEmail}")">@Lang.T("kontaktirate", "contact us")</MudLink>
                    @Lang.T(" direktno.", " directly.")
                </MudAlert>
            </MudContainer>
        }
    }
</div>

@code {
    [Parameter] public string? Slug { get; set; }

    private IRetreatEvent? _event;
    private string? _formId;
    private string _contactEmail = string.Empty;
    private bool _isLoading = true;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (!string.IsNullOrEmpty(Slug))
            {
                _event = await ContentfulService.GetEventBySlugAsync(Slug);
                _formId = _event?.TallyFormId;
            }

            if (string.IsNullOrEmpty(_formId))
            {
                var config = await ContentfulService.GetSiteConfigAsync();
                _formId = config?.DefaultTallyFormId;
                _contactEmail = config?.ContactEmail ?? string.Empty;
            }
        }
        catch (Exception)
        {
            _errorMessage = Lang.T("Nije moguće učitati formular. Pokušajte ponovo.", "Unable to load registration form. Please try again later.");
        }
        finally
        {
            _isLoading = false;
        }
    }
}
