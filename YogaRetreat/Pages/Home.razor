@page "/"
@inject IContentfulService ContentfulService
@inject LanguageService Lang

<PageTitle>@(_siteConfig?.SiteName ?? "Šumozov")</PageTitle>

@if (_isLoading)
{
    <div style="padding:2rem;">
        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="60vh" />
        <MudContainer MaxWidth="MaxWidth.Large" Style="margin-top:3rem;">
            <MudGrid>
                @for (int i = 0; i < 3; i++)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="320px" />
                    </MudItem>
                }
            </MudGrid>
        </MudContainer>
    </div>
}
else if (!string.IsNullOrEmpty(_errorMessage))
{
    <MudContainer MaxWidth="MaxWidth.Medium" Style="padding-top:3rem;">
        <MudAlert Severity="Severity.Error">@_errorMessage</MudAlert>
    </MudContainer>
}
else
{
    <div style="position:relative; min-height:60vh; display:flex; align-items:center; justify-content:center; padding:4rem 1rem; overflow:hidden;">        
        <div style="position:absolute; inset:0; background:rgba(245,240,232,0.55); z-index:1;"></div>
        <div style="position:relative; z-index:2; display:flex; flex-direction:column; align-items:center; text-align:center; gap:1.5rem;">
            <div style="position:relative; display:inline-block;">
                <img src="images/place/logo.png" alt="Šumozov" style="width:min(380px, 80vw); display:block;" />
                <div style="position:absolute; bottom:0; left:0; right:0; padding:1rem 1.5rem 1.25rem; background:linear-gradient(transparent, rgba(245,240,232,0.85));">
                    <MudText Typo="Typo.h6" Style="color:#3D5432; font-weight:400; letter-spacing:0.04em;">
                        @(_siteConfig?.Tagline ?? Lang.T("Udahni miris borova. Izdahni stres.", "Breathe in the pine forest. Breathe out the stress."))
                    </MudText>
                </div>
            </div>
            <MudButton Href="/events"
                       Variant="Variant.Filled"
                       Size="Size.Large"
                       Style="background:#3D5432; color:#F5F0E8; padding:0.75rem 2.5rem; font-size:1rem; letter-spacing:0.05em; border-radius:4px;">
                @Lang.T("Kalendar događaja", "Explore events")
            </MudButton>
        </div>
    </div>
    <MudContainer MaxWidth="MaxWidth.Medium" Style="padding:4rem 1rem 3rem;">
        <MudText Typo="Typo.h4" Align="Align.Center" Style="margin-bottom:2rem; font-weight:600;">@Lang.T("Ovako je sve počelo", "")</MudText>
        <MudText Typo="Typo.body1" Align="Align.Center" Style="color:#5A5A5A; line-height:1.9; max-width:640px; margin:0 auto;">
            Godinama smo lutali neutabanim stazama Fruške gore i svaki put pogledom zastajali na jednoj usamljenoj vikendici na susednom brdu. Pitali smo se kome pripada i kako se do nje stiže.<br /><br />
            U decembru 2021. saznali smo da je na prodaju. Delovalo je neverovatno da je to baš ta kuća — a još manje verovatno da bismo baš mi mogli postati njeni novi srećni vlasnici.<br /><br />
            Nakon nekoliko godina krčenja, košenja, sečenja, krečenja, gletovanja, šmirglanja... i mnogo strpljenja, ovo mesto postalo je naša šumska oaza u kojoj danas postoje samo tišina, zelenilo i osećaj da vreme teče malo sporije.<br /><br />
            I najbolje od svega — nije fatamorgana!
        </MudText>
            @* <MudTimeline TimelineAlign="TimelineAlign.Start">
            @foreach (var item in _schedule)
            {
                <MudTimelineItem Color="item.Color" Size="Size.Small">
                    <ItemContent>
                        <MudText Typo="Typo.subtitle1" Style="font-weight:600;">@Lang.T(item.TitleSr, item.TitleEn)</MudText>
                        <MudText Typo="Typo.body2" Style="color:#5A5A5A;">@Lang.T(item.BodySr, item.BodyEn)</MudText>
                    </ItemContent>
                </MudTimelineItem>
            }
        </MudTimeline> *@
    </MudContainer>
   @*  <MudContainer MaxWidth="MaxWidth.Medium" Style="padding:4rem 1rem 3rem;">
        <MudText Typo="Typo.h4" Align="Align.Center" Style="margin-bottom:2rem; font-weight:600;">@Lang.T("Plan puta", "Day Schedule")</MudText>
        <MudTimeline TimelineAlign="TimelineAlign.Start">
            @foreach (var item in _schedule)
            {
                <MudTimelineItem Color="item.Color" Size="Size.Small">
                    <ItemContent>
                        <MudText Typo="Typo.subtitle1" Style="font-weight:600;">@Lang.T(item.TitleSr, item.TitleEn)</MudText>
                        <MudText Typo="Typo.body2" Style="color:#5A5A5A;">@Lang.T(item.BodySr, item.BodyEn)</MudText>
                    </ItemContent>
                </MudTimelineItem>
            }
        </MudTimeline>
    </MudContainer> *@

    @if (_featuredEvents.Any())
    {
        <MudContainer MaxWidth="MaxWidth.Large" Style="padding:2rem 1rem 3rem;">
            <MudText Typo="Typo.h3" Align="Align.Center" Style="margin-bottom:0.5rem;">@Lang.T("Izdvojeni događaji", "Featured Events")</MudText>
            <MudText Typo="Typo.body1" Align="Align.Center" Style="color:#5A5A5A; margin-bottom:3rem;">
                @Lang.T("Pažljivo odabrana transformativna iskustva za sve nivoe", "Carefully selected transformative experiences for all levels")
            </MudText>
            <MudGrid Justify="Justify.Center">
                @foreach (var ev in _featuredEvents.Take(3))
                {
                    <MudItem xs="12" sm="6" md="4">
                        <EventCard Event="ev" />
                    </MudItem>
                }
            </MudGrid>
            <div style="text-align:center; margin-top:2.5rem;">
                <MudButton Href="/events" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large">
                    @Lang.T("Pogledajte sve retreate", "View all retreats")
                </MudButton>
            </div>
        </MudContainer>
    }

    @if (_testimonials.Any())
    {
        <MudContainer MaxWidth="MaxWidth.Large" Style="padding:2rem 1rem 4rem;">
            <TestimonialSlider Testimonials="_testimonials" />
        </MudContainer>
    }
}

@code {
    [CascadingParameter] private ISiteConfig? _siteConfig { get; set; }

    private IReadOnlyList<IRetreatEvent> _featuredEvents = Array.Empty<IRetreatEvent>();
    private IReadOnlyList<ITestimonial> _testimonials = Array.Empty<ITestimonial>();
    private bool _isLoading = true;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var eventsTask = ContentfulService.GetFeaturedEventsAsync();
            var testimonialsTask = ContentfulService.GetTestimonialsAsync();
            await Task.WhenAll(eventsTask, testimonialsTask);
            _featuredEvents = eventsTask.Result;
            _testimonials = testimonialsTask.Result;
        }
        catch (Exception)
        {
            _errorMessage = Lang.T("Nije moguće učitati sadržaj. Pokušajte ponovo.", "Unable to load content. Please try again.");
        }
        finally
        {
            _isLoading = false;
        }
    }
}
