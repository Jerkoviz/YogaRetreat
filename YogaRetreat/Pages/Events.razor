@page "/events"
@inject LanguageService Lang
@implements IDisposable

<PageTitle>@Lang.T("Kalendar događaja", "Events")</PageTitle>

<div style="padding-top:64px;">
    <MudContainer MaxWidth="MaxWidth.Large" Style="padding:3rem 1rem;">
        <MudText Typo="Typo.h3" Style="margin-bottom:0.5rem;">@Lang.T("Svi događaji", "All Events")</MudText>
        <MudText Typo="Typo.body1" Style="color:#5A5A5A; margin-bottom:2.5rem;">
            @Lang.T("Otkrijte predstojeće događaje", "Explore upcoming events")
        </MudText>

        <MudExpansionPanels MultiExpansion="false" Elevation="2">
            @foreach (var ev in _events)
            {
                <MudExpansionPanel>
                    <TitleContent>
                        <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:0.75rem; width:100%; padding:0.25rem 0;">
                            <div>
                                <MudText Typo="Typo.h6" Style="font-weight:600; margin-bottom:0.2rem;">@Lang.T(ev.TitleSr, ev.TitleEn)</MudText>
                                <div style="display:flex; gap:1rem; flex-wrap:wrap;">
                                    @if (!string.IsNullOrEmpty(ev.Location))
                                    {
                                        <div style="display:flex; align-items:center; gap:0.3rem; color:#5A5A5A;">
                                            <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" />
                                            <MudText Typo="Typo.body2">@ev.Location</MudText>
                                        </div>
                                    }
                                    @if (!string.IsNullOrEmpty(ev.DateSr) || !string.IsNullOrEmpty(ev.DateEn))
                                    {
                                        <div style="display:flex; align-items:center; gap:0.3rem; color:#5A5A5A;">
                                            <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" />
                                            <MudText Typo="Typo.body2">@Lang.T(ev.DateSr, ev.DateEn)</MudText>
                                        </div>
                                    }
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(ev.PriceDisplay))
                            {
                                <MudChip T="string" Color="Color.Secondary" Variant="Variant.Filled" Style="font-weight:600;">@ev.PriceDisplay</MudChip>
                            }
                        </div>
                    </TitleContent>
                    <ChildContent>
                        <MudDivider Style="margin-bottom:1.5rem;" />

                        @if (!string.IsNullOrEmpty(ev.DescriptionSr) || !string.IsNullOrEmpty(ev.DescriptionEn))
                        {
                            <MudText Typo="Typo.body1" Style="color:#5A5A5A; margin-bottom:2rem; line-height:1.8;">
                                @Lang.T(ev.DescriptionSr, ev.DescriptionEn)
                            </MudText>
                        }

                        @if (ev.Schedule.Length > 0)
                        {
                            <MudText Typo="Typo.h6" Style="font-weight:600; margin-bottom:1rem;">@Lang.T("Plan dana", "Day Schedule")</MudText>
                            <MudTimeline TimelineAlign="TimelineAlign.Start">
                                @foreach (var item in ev.Schedule)
                                {
                                    <MudTimelineItem Color="@item.Color" Size="Size.Small">
                                        <ItemContent>
                                            <MudText Typo="Typo.subtitle1" Style="font-weight:600;">@Lang.T(item.TitleSr, item.TitleEn)</MudText>
                                            <MudText Typo="Typo.body2" Style="color:#5A5A5A;">@Lang.T(item.BodySr, item.BodyEn)</MudText>
                                        </ItemContent>
                                    </MudTimelineItem>
                                }
                            </MudTimeline>
                        }

                        <MudPaper Elevation="0" Style="background:#F5F0E8; border-radius:8px; padding:1.25rem 1.5rem; margin-top:2rem;">
                            <div style="display:flex; align-items:center; gap:0.5rem; margin-bottom:0.5rem;">
                                <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Style="color:#3D5432;" />
                                <MudText Typo="Typo.subtitle2" Style="color:#3D5432; font-weight:600;">
                                    @Lang.T("Prijava", "How to register")
                                </MudText>
                            </div>
                            <MudText Typo="Typo.body2" Style="color:#5A5A5A; line-height:1.7;">
                                @Lang.T(
                                    "Prijava je moguća pozivom ili porukom na Instagram. Kontaktirajte nas na +381 69 350 6437 ili putem Instagram poruke.",
                                    "Registration is available by phone call or Instagram message. Contact us at +381 69 350 6437 or via Instagram message."
                                )
                            </MudText>
                        </MudPaper>
                    </ChildContent>
                </MudExpansionPanel>
            }
        </MudExpansionPanels>

        @if (!_events.Any())
        {
            <MudAlert Severity="Severity.Info">@Lang.T("Trenutno nema planiranih događaja. Uskoro se vraćamo!", "No upcoming events currently. Stay tuned!")</MudAlert>
        }
    </MudContainer>
</div>

@code {
    protected override void OnInitialized() => Lang.OnChanged += OnLanguageChanged;
    private void OnLanguageChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Lang.OnChanged -= OnLanguageChanged;

    private record ScheduleItem(string TitleSr, string TitleEn, string BodySr, string BodyEn, Color Color);

    private record LocalEvent(
        string TitleSr, string TitleEn,
        string DateSr, string DateEn,
        string DescriptionSr, string DescriptionEn,
        string? PriceDisplay,
        string? Location,
        ScheduleItem[] Schedule
    );

