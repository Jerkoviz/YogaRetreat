@namespace YogaRetreat.Shared
@inject LanguageService Lang

<MudPaper Elevation="0" Style="background:#2D2D2D; color:#F8F5F0; margin-top:4rem; padding:3rem 1rem 1.5rem;">
    <MudContainer MaxWidth="MaxWidth.Large">
        <MudGrid>

            <MudItem xs="12" sm="4">
                <MudText Typo="Typo.h6" Style="color:#F8F5F0; margin-bottom:0.75rem;">
                    @(SiteConfig?.SiteName ?? "Šumozov")
                </MudText>
                <div style="display:flex; align-items:center; gap:0.5rem;">
                    <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Style="color:#B0ADA8;" />
                    <MudLink Href="https://www.google.com/maps?q=45.123830,19.739606" Target="_blank" Style="color:#B0ADA8; font-size:0.9rem;">
                        45.123830, 19.739606
                    </MudLink>
                </div>
            </MudItem>

            <MudItem xs="12" sm="4">
                <MudText Typo="Typo.subtitle2" Style="color:#F8F5F0; margin-bottom:0.75rem; text-transform:uppercase; letter-spacing:0.08em; font-size:0.8rem;">
                    @Lang.T("Kontakt", "Contact")
                </MudText>
                <div style="display:flex; flex-direction:column; gap:0.6rem;">
                    <div style="display:flex; align-items:center; gap:0.5rem;">
                        <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" Style="color:#B0ADA8;" />
                        <MudLink Href="tel:+381693506437" Style="color:#B0ADA8; font-size:0.9rem;">+381 69 350 6437</MudLink>
                    </div>
                    <div style="display:flex; align-items:center; gap:0.5rem;">
                        <MudIcon Icon="@Icons.Material.Filled.Email" Size="Size.Small" Style="color:#B0ADA8;" />
                        <MudLink Href="mailto:sumozov@gmail.com" Style="color:#B0ADA8; font-size:0.9rem;">sumozov@gmail.com</MudLink>
                    </div>
                </div>
            </MudItem>

            <MudItem xs="12" sm="4">
                <MudText Typo="Typo.subtitle2" Style="color:#F8F5F0; margin-bottom:0.75rem; text-transform:uppercase; letter-spacing:0.08em; font-size:0.8rem;">
                    @Lang.T("Pratite nas", "Follow us")
                </MudText>
                <div style="display:flex; gap:0.5rem; flex-wrap:wrap; align-items:center;">
                    <MudIconButton Icon="@Icons.Custom.Brands.Instagram"
                                   Href="@(SiteConfig?.InstagramUrl ?? "https://www.instagram.com/ravnotezim_yogastudio?igsh=amVreG1vaHB6Nmhx")"
                                   Target="_blank"
                                   Style="color:#B0ADA8;" />
                    @if (!string.IsNullOrEmpty(SiteConfig?.FacebookUrl))
                    {
                        <MudIconButton Icon="@Icons.Custom.Brands.Facebook"
                                       Href="@SiteConfig.FacebookUrl"
                                       Target="_blank"
                                       Style="color:#B0ADA8;" />
                    }
                    @if (!string.IsNullOrEmpty(SiteConfig?.YouTubeUrl))
                    {
                        <MudIconButton Icon="@Icons.Custom.Brands.YouTube"
                                       Href="@SiteConfig.YouTubeUrl"
                                       Target="_blank"
                                       Style="color:#B0ADA8;" />
                    }
                </div>
            </MudItem>

        </MudGrid>

        <MudDivider Style="background:#444; margin:2rem 0 1rem;" />
        <MudText Typo="Typo.caption" Style="color:#6B6866; text-align:center; display:block;">
            &copy; @DateTime.Now.Year @(SiteConfig?.SiteName ?? "Šumozov"). @Lang.T("Sva prava zadržana.", "All rights reserved.")
        </MudText>
    </MudContainer>
</MudPaper>

@code {
    [Parameter] public ISiteConfig? SiteConfig { get; set; }
}
