@inject NavigationManager Nav
@inject LanguageService Lang

<MudAppBar Elevation="1" Color="Color.Primary" Fixed="true">
    <MudIconButton Icon="@Icons.Material.Filled.Menu"
                   Color="Color.Inherit"
                   Edge="Edge.Start"
                   OnClick="ToggleDrawer"
                   Class="d-flex d-md-none" />

    <MudLink Href="/" Class="d-flex align-center" Style="text-decoration:none; gap:0.5rem; color:white;">
        @if (!string.IsNullOrEmpty(SiteConfig?.LogoUrl))
        {
            <img src="@SiteConfig.LogoUrl" alt="@(SiteConfig?.SiteName ?? "Šumozov")" style="height:36px;" />
        }
        <MudText Typo="Typo.h6" Style="color:white; font-weight:600;">
            @(SiteConfig?.SiteName ?? "Šumozov")
        </MudText>
    </MudLink>

    <MudSpacer />

    <MudHidden Breakpoint="Breakpoint.SmAndDown" Invert="false">
        <MudButton Href="/" Color="Color.Inherit" Variant="Variant.Text">@Lang.T("Početna", "Home")</MudButton>
        @* <MudButton Href="/events" Color="Color.Inherit" Variant="Variant.Text">@Lang.T("Retreati", "Retreats")</MudButton> *@
        <MudButton Href="/gallery" Color="Color.Inherit" Variant="Variant.Text">@Lang.T("Galerija", "Gallery")</MudButton>
        <MudButton Href="/about-us" Color="Color.Inherit" Variant="Variant.Text">@Lang.T("O nama", "About Us")</MudButton>
    </MudHidden>

    <MudButton Size="Size.Small" Color="Color.Inherit"
               Variant="@(Lang.Current == "sr" ? Variant.Outlined : Variant.Text)"
               Style="min-width:36px; padding:0 8px;"
               OnClick="@(() => SetLang("sr"))">SR</MudButton>
    <MudButton Size="Size.Small" Color="Color.Inherit"
               Variant="@(Lang.Current == "en" ? Variant.Outlined : Variant.Text)"
               Style="min-width:36px; padding:0 8px;"
               OnClick="@(() => SetLang("en"))">EN</MudButton>
</MudAppBar>

<MudDrawer @bind-Open="_drawerOpen" Elevation="2" Variant="DrawerVariant.Temporary">
    <MudDrawerHeader>
        <MudText Typo="Typo.h6">@Lang.T("Meni", "Menu")</MudText>
    </MudDrawerHeader>
    <MudNavMenu>
        <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home" OnClick="CloseDrawer">@Lang.T("Početna", "Home")</MudNavLink>
        @* <MudNavLink Href="/events" Icon="@Icons.Material.Filled.Event" OnClick="CloseDrawer">@Lang.T("Retreati", "Retreats")</MudNavLink> *@
        <MudNavLink Href="/gallery" Icon="@Icons.Material.Filled.PhotoLibrary" OnClick="CloseDrawer">@Lang.T("Galerija", "Gallery")</MudNavLink>
        <MudNavLink Href="/about-us" Icon="@Icons.Material.Filled.People" OnClick="CloseDrawer">@Lang.T("O nama", "About Us")</MudNavLink>
    </MudNavMenu>
</MudDrawer>

@code {
    [Parameter] public ISiteConfig? SiteConfig { get; set; }

    private bool _drawerOpen;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private void CloseDrawer() => _drawerOpen = false;
    private async Task SetLang(string lang) => await Lang.SetAsync(lang);
}
